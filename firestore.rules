rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidReport(data) {
      return (data.userId == request.auth.uid || data.userId != null) &&
             data.category is string && data.category.size() <= 100 &&
             data.severity is string && data.severity.size() <= 20 &&
             data.status is string && data.status.size() <= 20 &&
             data.summary is string && data.summary.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.location is map && data.location.keys().hasAll(['lat', 'lng']) &&
             data.imageUrl is string && data.imageUrl.size() <= 2000 &&
             data.createdAt is number && data.createdAt <= request.time.toMillis();
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if isValidId(reportId) && isValidReport(incoming());
      allow update: if isValidId(reportId);
      allow delete: if true;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(commentId) && incoming().userId == request.auth.uid && incoming().reportId == reportId && incoming().text is string && incoming().text.size() <= 1000 && incoming().createdAt is number;
        allow update: if false;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }

      match /votes/{voteId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(voteId) && incoming().userId == request.auth.uid && incoming().reportId == reportId && incoming().type in ['upvote', 'downvote'] && incoming().createdAt is number;
        allow update: if false;
        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && incoming().name is string && incoming().name.size() <= 100 && incoming().role in ['citizen', 'admin'] && incoming().score is number;
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
    }
  }
}
