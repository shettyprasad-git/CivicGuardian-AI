{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A civic issue reported by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "status": { "type": "string" },
        "suggestedDepartment": { "type": "string" },
        "suggestedPriority": { "type": "string" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "impact": { "type": "string" },
        "action": { "type": "string" },
        "location": { "type": "object" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "votes": { "type": "number" }
      },
      "required": ["userId", "userName", "category", "severity", "status", "summary", "description", "location", "imageUrl", "createdAt", "updatedAt", "votes"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoUrl": { "type": "string" },
        "role": { "type": "string" },
        "score": { "type": "number" }
      },
      "required": ["name", "role", "score"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a report.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["reportId", "userId", "userName", "text", "createdAt"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A vote on a report.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["reportId", "userId", "type", "createdAt"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Stores issue reports."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/reports/{reportId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on a report."
    },
    "/reports/{reportId}/votes/{voteId}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Votes on a report."
    }
  }
}
